# =========================================================
# IBM i Legacy Agent Migrator - .env.example
# =========================================================
# Instrucciones:
# 1) Copia este archivo a .env
# 2) Completa SOLO el proveedor que usaras
# 3) No subas el archivo .env real al repositorio

# ---------------------------------------------------------
# App / entorno general
# ---------------------------------------------------------
APP_ENV=development
DEBUG=False
LOG_LEVEL=INFO

SECRET_KEY=replace_with_secure_random_value
DATABASE_URL=sqlite:///db.sqlite3

# Proveedor LLM por defecto para tu app
# Valores sugeridos: openai | anthropic | vertex_gemini | azure_openai | ollama
LLM_PROVIDER=openai

# Parametros comunes para cualquier proveedor
LLM_DEFAULT_MODEL=gpt-4o
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=60

# ---------------------------------------------------------
# OpenAI
# ---------------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# Opcional: URL custom/proxy compatible OpenAI
OPENAI_BASE_URL=https://api.openai.com/v1
# Opcional: para organizaciones/proyectos
OPENAI_ORG_ID=
OPENAI_PROJECT=

# ---------------------------------------------------------
# Anthropic
# ---------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Opcional
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01

# ---------------------------------------------------------
# Google Vertex AI + Gemini (entorno enterprise recomendado)
# ---------------------------------------------------------
# Proyecto y region de GCP
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Ruta al JSON de Service Account (ADC)
# Windows: C:/keys/service-account.json
# Linux/macOS: /opt/keys/service-account.json
GOOGLE_APPLICATION_CREDENTIALS=

# Modelo Gemini en Vertex
VERTEX_GEMINI_MODEL=gemini-1.5-pro

# Opcional: endpoint regional explicito
VERTEX_AI_ENDPOINT=

# ---------------------------------------------------------
# Google AI Studio Gemini (alternativa simple a Vertex)
# ---------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ---------------------------------------------------------
# Azure OpenAI (muy recomendado en entornos corporativos)
# ---------------------------------------------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ---------------------------------------------------------
# Proveedor recomendado adicional: Ollama (local/on-prem)
# ---------------------------------------------------------
# Ideal para pruebas locales sin exponer datos sensibles a nube publica
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ---------------------------------------------------------
# Extras opcionales
# ---------------------------------------------------------
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1
