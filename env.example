# =========================================================
# IBM i Legacy Agent Migrator - .env.example
# =========================================================
# Instrucciones:
# 1) Copia este archivo a .env
# 2) Completa SOLO el proveedor que usaras
# 3) No subas el archivo .env real al repositorio

# ---------------------------------------------------------
# App / entorno general
# ---------------------------------------------------------
APP_ENV=development
DEBUG=False
LOG_LEVEL=INFO

SECRET_KEY=replace_with_secure_random_value
# Para AUTH_PROVIDER=postgres usa formato:
# postgresql://agente_user:agente_password@localhost:5432/agente_db
DATABASE_URL=

# Proveedor de autenticación de la app: env | postgres | sqlserver
AUTH_PROVIDER=env

# Proveedor único para autenticación y perfiles en BD: env | postgres | sqlserver
# La aplicación usa únicamente AUTH_PROVIDER para rutas de base de datos.

# Configuración SQL Server 2022 (si AUTH_PROVIDER=sqlserver)
SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
SQLSERVER_HOST=
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=
SQLSERVER_USER=
SQLSERVER_PASSWORD=
SQLSERVER_TRUST_SERVER_CERTIFICATE=yes

# Autenticacion local app (hash SHA-256)
# Opcion A: un usuario simple
AUTH_USER=
AUTH_PASSWORD=
# Opcion B: multiples usuarios en JSON: {"user":"sha256_hash", ...}
AUTH_USERS_JSON=

# Perfiles y admins de UI (configuración externa)
# USER_PROFILES_JSON ejemplo:
# {"sergio.cuevas.d":["SFTP","DTSX","Documentation"],"carlos.ramirez":["SFTP","Documentation"]}
USER_PROFILES_JSON={"sergio.cuevas.d":["SFTP","COBOL","DTSX","RequirementWorkflow","Documentation"],"carlos.ramirez":["SFTP","RequirementWorkflow","Documentation"]}
# Lista de admins separada por coma (deben existir en USER_PROFILES_JSON)
ADMINS_CSV=sergio.cuevas.d

# Proveedor LLM por defecto para tu app
# Valores sugeridos: openai | anthropic | vertex_gemini | azure_openai | ollama
LLM_PROVIDER=openai

# Parametros comunes para cualquier proveedor
LLM_DEFAULT_MODEL=gpt-4o
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=60

# ---------------------------------------------------------
# OpenAI
# ---------------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# Opcional: URL custom/proxy compatible OpenAI
OPENAI_BASE_URL=https://api.openai.com/v1
# Opcional: para organizaciones/proyectos
OPENAI_ORG_ID=
OPENAI_PROJECT=

# ---------------------------------------------------------
# Anthropic
# ---------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Opcional
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01

# ---------------------------------------------------------
# Google Vertex AI + Gemini (entorno enterprise recomendado)
# ---------------------------------------------------------
# Proyecto y region de GCP
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Ruta al JSON de Service Account (ADC)
# Windows: C:/keys/service-account.json
# Linux/macOS: /opt/keys/service-account.json
GOOGLE_APPLICATION_CREDENTIALS=

# Modelo Gemini en Vertex
VERTEX_GEMINI_MODEL=gemini-1.5-pro

# Opcional: endpoint regional explicito
VERTEX_AI_ENDPOINT=

# ---------------------------------------------------------
# Google AI Studio Gemini (alternativa simple a Vertex)
# ---------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ---------------------------------------------------------
# Azure OpenAI (muy recomendado en entornos corporativos)
# ---------------------------------------------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ---------------------------------------------------------
# Proveedor recomendado adicional: Ollama (local/on-prem)
# ---------------------------------------------------------
# Ideal para pruebas locales sin exponer datos sensibles a nube publica
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ---------------------------------------------------------
# Extras opcionales
# ---------------------------------------------------------
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# Timeouts y reintentos HTTP para integraciones (Jira/Confluence)
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=2
HTTP_BACKOFF_SECONDS=0.5

# ---------------------------------------------------------
# Jira
# ---------------------------------------------------------
JIRA_USER=
JIRA_PASSWORD=
JIRA_BASE_URL=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Story